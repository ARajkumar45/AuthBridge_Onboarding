# ══════════════════════════════════════════════════════
# AuthBridge AI-Native Onboarding — Environment Config
# ══════════════════════════════════════════════════════

# ── NVIDIA API (free tier at build.nvidia.com) ──
NVIDIA_API_KEY=your_nvidia_api_key_here

# ── Model Configuration ──
NVIDIA_LLM_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# ── Application ──
APP_ENV=development
FASTAPI_PORT=8000
STREAMLIT_PORT=8501

# ── Database ──
SQLITE_DB_PATH=./authbridge.db

# ── ChromaDB ──
CHROMA_PERSIST_DIR=./chroma_db

# ── Security ──
SECRET_KEY=change-me-in-production-use-uuid4
