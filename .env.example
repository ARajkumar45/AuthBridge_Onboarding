# AuthBridge Onboarding — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── NVIDIA API (required) ────────────────────────────────────────────────────
# Get a free key at https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your-key-here

# ── NVIDIA Model Selection (optional — defaults shown) ───────────────────────
NVIDIA_LLM_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# ── Database (optional — defaults shown) ─────────────────────────────────────
SQLITE_DB_PATH=./authbridge.db

# ── ChromaDB (optional — defaults shown) ─────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── FastAPI (optional) ────────────────────────────────────────────────────────
# SECRET_KEY is used for session signing — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-real-secret-with-python-secrets-module
